{
  "name": "jewellery-e-commerce-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "nodemon --exec tsx server.ts",
    "dev:live": "env-cmd -f .env.dev nodemon --exec tsx server.ts",
    "prod": "nodemon --exec tsx server.ts",
    "serve": "env-cmd -f .env nodemon --exec tsx server.ts",
    "start": "node dist/server.js",
    "generate": "prisma generate",
    "watch": "nodemon --watch 'src/**' --exec tsx server.ts",
    "generate:key": "node src/utils/generateKey.js",
    "render:build": "npm install && npm run build && npx puppeteer browsers install chrome"
  },
